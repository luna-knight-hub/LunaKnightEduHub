# ============================================
# LunaKnightEduHub — Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git!

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # ⚠️ Server-only, no NEXT_PUBLIC_ prefix

# --- Sanity CMS ---
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=                   # Server-only

# --- Python Backend (Game API) ---
PYTHON_API_URL=                     # e.g., http://localhost:8000
INTERNAL_API_SECRET=                # Shared secret for proxy auth

# --- Sanity Webhook (On-demand ISR) ---
SANITY_WEBHOOK_SECRET=
